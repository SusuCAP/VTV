VTV_ENVIRONMENT=local
VTV_DATABASE_URL=postgresql+asyncpg://vtv:vtv@127.0.0.1:5432/vtv
VTV_TEST_DATABASE_URL=postgresql+asyncpg://vtv:vtv@127.0.0.1:5432/vtv_test

# S3-compatible object storage (MinIO in local compose)
VTV_S3_ENDPOINT=http://127.0.0.1:9000
VTV_S3_ACCESS_KEY=vtv
VTV_S3_SECRET_KEY=change-me-in-non-local-environments
VTV_S3_BUCKET=vtv-local

# Optional: HuggingFace token for gated models (pyannote/speaker-diarization etc.)
VTV_HF_TOKEN=

# Required outside VTV_ENVIRONMENT=local
VTV_API_KEY=
VITE_WORKSPACE_ID=

# Model runtime adapter modes — real production defaults are enforced in code.
# Deterministic/passthrough values are for isolated contract tests only.
# Possible values documented in configs/environments/*.yaml
# ASR/VAD: local_models | remote
VTV_ASR_ADAPTER_MODE=remote
# Vision analysis: qwen3_vl | remote
VTV_VISION_ADAPTER_MODE=remote
# Segmentation: sam3 | remote
VTV_SEGMENTATION_ADAPTER_MODE=sam3
# Visual generation: wan_animate | mocha | vace | ltx23 | remote
VTV_VISUAL_GENERATION_ADAPTER_MODE=wan_animate
# TTS: cosyvoice3 | remote_tts
VTV_TTS_ADAPTER_MODE=remote_tts
# Lipsync: latentsync | remote_lipsync
VTV_LIPSYNC_ADAPTER_MODE=remote_lipsync
