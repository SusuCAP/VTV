VTV_ENVIRONMENT=local
VTV_DATABASE_URL=postgresql+asyncpg://vtv:vtv@127.0.0.1:5432/vtv
VTV_TEST_DATABASE_URL=postgresql+asyncpg://vtv:vtv@127.0.0.1:5432/vtv_test

# S3-compatible object storage (MinIO in local compose)
VTV_S3_ENDPOINT=http://127.0.0.1:9000
VTV_S3_ACCESS_KEY=vtv
VTV_S3_SECRET_KEY=change-me-in-non-local-environments
VTV_S3_BUCKET=vtv-local

# Optional: HuggingFace token for gated models (pyannote/speaker-diarization etc.)
VTV_HF_TOKEN=

# Optional: API key for Bearer token auth (empty = auth disabled, local dev only)
VTV_API_KEY=

# Model runtime adapter modes — override per environment
# Possible values documented in configs/environments/*.yaml
# ASR/VAD: deterministic | local_models | remote
VTV_ASR_ADAPTER_MODE=deterministic
# Vision analysis: deterministic | qwen3_vl | remote
VTV_VISION_ADAPTER_MODE=deterministic
# Segmentation: passthrough | sam3 | remote
VTV_SEGMENTATION_ADAPTER_MODE=passthrough
# Visual generation: passthrough | wan_animate | remote
VTV_VISUAL_GENERATION_ADAPTER_MODE=passthrough
# TTS: passthrough | cosyvoice3 | remote_tts
VTV_TTS_ADAPTER_MODE=passthrough
# Lipsync: passthrough | latentsync | remote_lipsync
VTV_LIPSYNC_ADAPTER_MODE=passthrough
