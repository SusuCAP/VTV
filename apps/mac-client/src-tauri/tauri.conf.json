{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VTV Studio",
  "version": "0.1.0",
  "identifier": "com.vtv.studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "VTV Studio",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:5173 http://127.0.0.1:8000; connect-src 'self' http://localhost:5173 http://127.0.0.1:8000 https:; media-src 'self' blob: https:;"
    }
  },
  "bundle": {
    "active": true,
    "icon": [],
    "targets": ["dmg", "app"],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
