name: CI

on:
  push:
    branches: [main]
  pull_request:

jobs:
  python:
    runs-on: ubuntu-latest
    services:
      postgres:
        image: postgres:17-alpine
        env:
          POSTGRES_USER: vtv
          POSTGRES_PASSWORD: vtv
          POSTGRES_DB: vtv_test
        ports: ["5432:5432"]
        options: >-
          --health-cmd "pg_isready -U vtv -d vtv_test"
          --health-interval 5s
          --health-timeout 5s
          --health-retries 20
    env:
      VTV_TEST_DATABASE_URL: postgresql+asyncpg://vtv:vtv@127.0.0.1:5432/vtv_test
    steps:
      - uses: actions/checkout@v4
      - uses: astral-sh/setup-uv@v6
        with:
          enable-cache: true
      - run: uv sync --all-packages --locked
      - run: uv run ruff check .
      - run: uv run pytest

  mac-client-web:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: 22
          cache: npm
      - run: npm ci
      - run: npm run lint:mac
      - run: npm run build:mac
